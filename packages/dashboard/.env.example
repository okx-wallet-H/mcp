# ━━━━━ OKX API Credentials ━━━━━
# Get from https://www.okx.com/account/my-api
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Demo mode (true=simulated, false=live)
OKX_IS_DEMO=true

# ━━━━━ OKX WS Endpoints ━━━━━
OKX_WS_PUBLIC=wss://ws.okx.com:8443/ws/v5/public
OKX_WS_PRIVATE=wss://ws.okx.com:8443/ws/v5/private

# ━━━━━ XLayer Chain ━━━━━
XLAYER_WS_URL=wss://xlayerws.okx.com

# ━━━━━ MCP Gateway ━━━━━
MCP_GATEWAY_PORT=3457
